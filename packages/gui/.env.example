# ─── Supabase ──────────────────────────────────────────────────────────────
# From your Supabase project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── GitHub OAuth (configured inside Supabase Auth → Providers → GitHub) ──
# The GitHub OAuth App itself lives in Supabase; these are only needed if the
# server needs to call the GitHub API outside of user sessions.
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=

# ─── Anthropic (used by @cezar/core for action execution on the server) ──
ANTHROPIC_API_KEY=

# ─── Optional: seed / default workspace (used by dev scripts only) ──────
DEV_WORKSPACE_SLUG=open-mercato
