# ─── Supabase ──────────────────────────────────────────────────────────────
# From your Supabase project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── GitHub OAuth (configured inside Supabase Auth → Providers → GitHub) ──
# The GitHub OAuth App itself lives in Supabase; these are only needed if the
# server needs to call the GitHub API outside of user sessions.
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=

# ─── Anthropic (used by @cezar/core for action execution on the server) ──
ANTHROPIC_API_KEY=

# ─── Optional: seed / default workspace (used by dev scripts only) ──────
DEV_WORKSPACE_SLUG=open-mercato

# ─── App URL ────────────────────────────────────────────────────────────
# Public-facing URL of this Cezar deployment. Used by Settings → Runners to
# render the ready-to-paste `cezar-runner start` command, and by the in-process
# scheduler as the default `fetch` base URL.
NEXT_PUBLIC_APP_URL=https://cezar.your-domain.com

# ─── Cron auth ──────────────────────────────────────────────────────────
# Bearer token the cron routes (and the in-process scheduler) check.
# `/api/cron/dispatch` and `/api/cron/triage-sweep` use the same bearer check
# as the 6 legacy cron routes.
CRON_SECRET=

# ─── GitHub App (Phase 1 — additive; OAuth fallback if unset) ───────────
# Register a GitHub App per `docs/github-app-setup.md`. Without these, repo
# ops fall back to the user's OAuth token and the webhook receiver returns 503.
GITHUB_APP_ID=                  # numeric App ID
GITHUB_APP_PRIVATE_KEY=         # the PEM (literal \n is normalized to real newlines)
GITHUB_APP_WEBHOOK_SECRET=      # without it /api/github/webhook returns 503
                                #   and you rely on the /api/cron/triage-sweep poll fallback

# ─── Workflow engine cutover ────────────────────────────────────────────
# `true` flips the new workflow engine on globally; or set
# `config.workflow.useEngine` per-workspace instead. Default off → the legacy
# AutofixOrchestrator path runs unchanged.
CEZAR_USE_WORKFLOW_ENGINE=

# ─── Dispatcher knobs (/api/cron/dispatch) ──────────────────────────────
CEZAR_DISPATCH_BATCH=3                  # jobs claimed per tick (optional)
CEZAR_DISPATCH_STALE_MINUTES=15         # stalled-job re-queue cutoff (optional)
CEZAR_RUNNER_OFFLINE_MINUTES=3          # dead-runner job re-queue cutoff (optional)

# ─── Triage sweep knobs (/api/cron/triage-sweep) ────────────────────────
CEZAR_TRIAGE_SWEEP_BATCH=10             # triage jobs enqueued per workspace per tick (optional)

# ─── In-process scheduler (self-hosted Node deployments) ────────────────
# Set to `true` on a long-running Node host (Docker / Fly / Railway / Render /
# VPS) to start the in-process scheduler at server boot. Leave unset on Vercel.
CEZAR_INPROCESS_CRON=

# Base URL the scheduler fetches. Defaults to NEXT_PUBLIC_APP_URL /
# https://$VERCEL_URL / http://127.0.0.1:$PORT.
CEZAR_INPROCESS_CRON_BASE_URL=

# CSV of route paths to skip (optional), e.g.
#   /api/cron/ci-fix,/api/cron/issue-sync
CEZAR_INPROCESS_CRON_DISABLED=

# Set to `false` to skip every legacy cron route (run only dispatch +
# triage-sweep in-process and drive the 6 legacy ones externally).
# Default = run them all.
CEZAR_INPROCESS_CRON_LEGACY=

# ─── In-process scheduler intervals (ms) ────────────────────────────────
# Defaults match `packages/gui/vercel.json` cadences. All optional.
CEZAR_DISPATCH_INTERVAL_MS=60000              # 1 min
CEZAR_TRIAGE_SWEEP_INTERVAL_MS=600000         # 10 min
CEZAR_CRON_ISSUE_SYNC_INTERVAL_MS=300000      # 5 min
CEZAR_CRON_ISSUE_MATCH_INTERVAL_MS=60000      # 1 min
CEZAR_CRON_ISSUE_FIX_INTERVAL_MS=60000        # 1 min
CEZAR_CRON_CI_WATCH_INTERVAL_MS=60000         # 1 min
CEZAR_CRON_CI_ATTRIBUTE_INTERVAL_MS=60000     # 1 min
CEZAR_CRON_CI_FIX_INTERVAL_MS=60000           # 1 min
